[
  {
    "id": "eps_by_client",
    "description": "Event count and EPS calculation per client domain",
    "aql": "SELECT DOMAINNAME(domainid) AS metric, LONG(COUNT(*)) AS value FROM events GROUP BY domainid",
    "collection": "metricas_eps",
    "interval_minutes": 60,
    "mapping": {
      "metric": "cliente",
      "value": "eventos_totales"
    },
    "calculate_eps": true
  },
  {
    "id": "logsource_summary",
    "description": "Log source summary and event distribution",
    "collection": "logsource_summary",
    "aql": "SELECT LOGSOURCETYPENAME(devicetype) AS log_type, LOGSOURCENAME(logsourceid) AS log_name, SUM(eventcount) AS total, DOMAINNAME(domainid) AS client FROM events WHERE (log_type <> 'Health Metrics' AND log_type <> 'SIM Audit') AND log_type <> 'System Notification' GROUP BY logsourceid, domainid, devicetype ORDER BY total DESC",
    "mapping": {
      "log_type": "log_source_type",
      "log_name": "log_source",
      "total": "total_eventos",
      "client": "cliente"
    },
    "calculate_eps": true
  },
  {
    "id": "offenses_sync",
    "type": "rest_api",
    "endpoint": "/api/siem/offenses",
    "description": "Open offenses with magnitude > 4",
    "collection": "alertas_qradar",
    "interval_minutes": 5,
    "clear_before_sync": true,
    "params": {
      "filter": "status=\"open\" and magnitude >= 4",
      "sort": "-magnitude"
    },
    "headers": {
      "Range": "items=0-49",
      "Version": "23.0"
    },
    "mapping": {
      "id": "offense_id",
      "description": "descripcion",
      "source_network": "red_origen",
      "domain_id": "dominio_id",
      "status": "estado",
      "magnitude": "magnitud"
    },
    "domain_mapping": {
      "qradar_principal": {
        "0": "Cliente_Prueba_Interno",
        "1": "Cliente_Norte_Ventas",
        "2": "Cliente_Norte_Ventas",
        "3": "Cliente_Norte_Ventas"
      },
      "qradar_Casinos": {
        "0": "Casino_Central_PROD"
      }
    }
  }
]