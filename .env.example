# QRadar connection
QRADAR_IP=10.10.10.10
QRADAR_TOKEN=replace-with-qradar-token

# MongoDB connection
# Option A (recommended): full URI
# Used when MONGO_USER and MONGO_PASSWORD are empty.
MONGO_URI=mongodb://localhost:27017

# Option B (alternative): separate variables
# If MONGO_USER and MONGO_PASSWORD are set, this mode is used automatically.
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_USER=
MONGO_PASSWORD=
MONGO_AUTH_SOURCE=admin
MONGO_PARAMS=

MONGO_DB=qradar_metrics
MONGO_COLLECTION=eps_por_cliente

# Intervalo de sincronización (en MINUTOS)
# Esta variable controla 2 cosas:
# 1. La ventana de tiempo que se consulta a QRadar (últimos X minutos).
# 2. Cada cuánto tiempo se ejecuta el script automáticamente.
# Por ejemplo, si es 60, el script trae la última hora de datos cada 60 minutos.
SYNC_INTERVAL_MINUTES=60

# Zona horaria de negocio para los campos de fecha/hora en MongoDB.
APP_TIMEZONE=America/Santiago

# Controles opcionales de red y polling
REQUEST_TIMEOUT=30
POLL_INTERVAL_SECONDS=2
MAX_POLL_ATTEMPTS=120

# Modo continuo (Daemon)
# Mantener en 'true' para que el servicio se autoejecute según el intervalo definido arriba.
RUN_CONTINUOUS=true

# Optional debug output (set true only for tests)
DEBUG_EXPORT_TXT=false
DEBUG_TXT_FILE=debug_qradar_output.txt
