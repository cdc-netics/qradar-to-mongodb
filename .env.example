# QRadar instances (agregar tantos como necesites: QRADAR_1, QRADAR_2, ...)
QRADAR_1_NAME=qradar_principal
QRADAR_1_IP=10.10.10.10
QRADAR_1_TOKEN=replace-with-qradar-token
# (Opcional) Alias para reemplazar "Default Domain" en los datos de este QRadar.
# Si no se define, se usa QRADAR_1_NAME automáticamente.
#QRADAR_1_DEFAULT_DOMAIN_ALIAS=NombreCliente

#QRADAR_2_NAME=qradar_secundario
#QRADAR_2_IP=10.10.10.20
#QRADAR_2_TOKEN=replace-with-second-token
# (Opcional) Alias para el segundo QRadar.
#QRADAR_2_DEFAULT_DOMAIN_ALIAS=NombreCliente2

# MongoDB connection
# Option A (recommended): full URI
# Used when MONGO_USER and MONGO_PASSWORD are empty.
MONGO_URI=mongodb://localhost:27017

# Option B (alternative): separate variables
# If MONGO_USER and MONGO_PASSWORD are set, this mode is used automatically.
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_USER=
MONGO_PASSWORD=
MONGO_AUTH_SOURCE=admin
MONGO_PARAMS=

MONGO_DB=qradar_metrics
# MONGO_COLLECTION no es necesario; se define por tarea en queries.json

# Intervalo de sincronización (en MINUTOS)
# Esta variable controla 2 cosas:
# 1. La ventana de tiempo que se consulta a QRadar (últimos X minutos).
# 2. Cada cuánto tiempo se ejecuta el script automáticamente.
SYNC_INTERVAL_MINUTES=60

# Zona horaria de negocio para los campos de fecha/hora en MongoDB.
APP_TIMEZONE=America/Santiago

# Controles opcionales de red y polling
REQUEST_TIMEOUT=30
POLL_INTERVAL_SECONDS=2
MAX_POLL_ATTEMPTS=120

# Modo continuo (Daemon)
# Mantener en 'true' para que el servicio se autoejecute según el intervalo definido arriba.
RUN_CONTINUOUS=true

# Opciones de depuración (solo para pruebas)
DEBUG_EXPORT_TXT=false
DEBUG_TXT_FILE=debug_qradar_output.txt

# Logging
# LOG_LEVEL: DEBUG | INFO | WARNING | ERROR  (default: INFO)
#   - INFO  → inicio/fin de ciclo, tareas ejecutadas, registros insertados, advertencias.
#   - DEBUG → además: queries AQL enviadas, cada intento de polling, campos faltantes,
#             muestra del primer documento insertado y tareas omitidas por intervalo.
LOG_LEVEL=INFO

# LOG_FILE: ruta a un archivo de log con rotación automática.
# Si se deja vacío, solo se imprime en consola/journal.
LOG_FILE=/var/log/qradar-to-mongodb.log

# Tamaño máximo de cada archivo de log antes de rotar (bytes). Default: 5 MB.
LOG_MAX_BYTES=5242880

# Cuántos archivos de rotación conservar (qradar.log.1, .2, ...). Default: 5.
LOG_BACKUP_COUNT=5
