[
  {
    "id": "event_metrics_example",
    "type": "aql",
    "description": "Ejemplo de métricas de eventos por dominio",
    "aql": "SELECT DOMAINNAME(domainid) AS metric, COUNT(*) AS value FROM events GROUP BY domainid",
    "collection": "metricas_ejemplo",
    "interval_minutes": 60,
    "mapping": {
      "metric": "nombre_cliente",
      "value": "total_eventos"
    },
    "calculate_eps": true
  },
  {
    "id": "offenses_sync_example",
    "type": "rest_api",
    "endpoint": "/api/siem/offenses",
    "description": "Ejemplo de sincronización de ofensas abiertas",
    "collection": "alertas_ejemplo",
    "interval_minutes": 5,
    "clear_before_sync": true,
    "params": {
      "filter": "status=\"open\" and magnitude > 4",
      "sort": "-magnitude"
    },
    "headers": {
      "Range": "items=0-49",
      "Version": "23.0"
    },
    "mapping": {
      "id": "offense_id",
      "description": "descripcion_alerta",
      "domain_id": "cliente_id",
      "status": "estado_actual",
      "magnitude": "magnitud_riesgo"
    },
    "domain_mapping": {
      "nombre_qradar_1": {
        "0": "Empresa_A",
        "1": "Empresa_B"
      },
      "nombre_qradar_2": {
        "0": "Empresa_C"
      }
    }
  }
]
